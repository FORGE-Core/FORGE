// Cappi — Plataforma de capacitación empresarial multi-tenant
// PostgreSQL + pgvector (habilitar extensión en migración SQL)

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [pgvector(map: "vector", schema: "public")]
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  SUPERVISOR
  EMPLOYEE
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum DocumentType {
  PDF
  IMAGE
  VIDEO
  AUDIO
  MANUAL
  DIAGRAM
  PROCESS
}

enum DocumentStatus {
  UPLOADING
  PROCESSING
  READY
  FAILED
}

enum ActivityType {
  TRUE_FALSE
  MULTIPLE_CHOICE
  ORDER_STEPS
  SIMULATION
  ERROR_DETECTION
  CASE_STUDY
}

enum ModuleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AutomationTrigger {
  USER_COMPLETED_MODULE
  USER_FAILED_ACTIVITY
  DOCUMENT_PROCESSED
  LOW_SCORE_DETECTED
  CUSTOM_WEBHOOK
}

enum LearningModality {
  READING
  LISTENING
  VISUAL
  PRACTICE
  MIXED
}

enum LearningPace {
  SLOW
  NORMAL
  FAST
}

enum SupportLevel {
  STANDARD
  GUIDED
  SIMPLIFIED
  INTENSIVE
}

// ─── Multi-tenant core ───────────────────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logoUrl   String?
  industry  String?
  settings  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  modules       TrainingModule[]
  documents     Document[]
  processes     Process[]
  conversations Conversation[]
  automations   Automation[]
  reports         ReportSnapshot[]
  inclusionAudits InclusionAudit[]

  @@index([slug])
  @@map("organizations")
}

model User {
  id             String     @id @default(cuid())
  email          String     @unique
  passwordHash   String?
  name           String?
  image          String?
  role           UserRole   @default(EMPLOYEE)
  status         UserStatus @default(PENDING)
  organizationId String
  emailVerified  DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  accounts       Account[]
  sessions       Session[]
  progress       UserProgress[]
  activityAttempts ActivityAttempt[]
  conversations         Conversation[]
  learningEvents        LearningEvent[]
  accessibilityProfile  AccessibilityProfile?
  learningProfile       LearningProfile?
  accessibilityEvents   AccessibilityEvent[]
  contentAdaptations    ContentAdaptation[]
  pushSubscriptions     PushSubscription[]

  @@index([organizationId])
  @@index([organizationId, role])
  @@map("users")
}

// NextAuth
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Contenido de capacitación ───────────────────────────────────────────────

model TrainingModule {
  id             String       @id @default(cuid())
  organizationId String
  slug           String?
  title          String
  description    String?
  audience       String?
  status         ModuleStatus @default(DRAFT)
  orderIndex     Int          @default(0)
  estimatedMins  Int?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  processes    Process[]
  activities   Activity[]
  progress     UserProgress[]
  documents    Document[]

  @@unique([organizationId, slug])
  @@index([organizationId, status])
  @@map("training_modules")
}

model Process {
  id             String  @id @default(cuid())
  organizationId String
  moduleId       String?
  title          String
  description    String?
  steps          Json    @default("[]")
  orderIndex     Int     @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  module       TrainingModule? @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  documents    Document[]

  @@index([organizationId])
  @@index([moduleId])
  @@map("processes")
}

model Activity {
  id             String       @id @default(cuid())
  organizationId String
  moduleId       String
  type           ActivityType
  title          String
  content        Json
  difficulty     Int          @default(1)
  points         Int          @default(10)
  aiGenerated    Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  module    TrainingModule    @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  attempts  ActivityAttempt[]

  @@index([organizationId])
  @@index([moduleId])
  @@map("activities")
}

// ─── Documentos y RAG ────────────────────────────────────────────────────────

model Document {
  id             String         @id @default(cuid())
  organizationId String
  processId      String?
  moduleId       String?
  title          String
  type           DocumentType
  status         DocumentStatus @default(UPLOADING)
  fileUrl        String?
  mimeType       String?
  fileSize       Int?
  metadata       Json           @default("{}")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  process      Process?        @relation(fields: [processId], references: [id], onDelete: SetNull)
  module       TrainingModule? @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  chunks       DocumentChunk[]

  @@index([organizationId, status])
  @@index([moduleId])
  @@map("documents")
}

model DocumentChunk {
  id             String   @id @default(cuid())
  organizationId String
  documentId     String
  content        String   @db.Text
  chunkIndex     Int
  tokenCount     Int?
  metadata       Json     @default("{}")
  // embedding almacenado vía raw SQL pgvector — ver lib/vector
  createdAt      DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([organizationId])
  @@map("document_chunks")
}

// ─── Progreso y aprendizaje adaptativo ───────────────────────────────────────

model UserProgress {
  id             String   @id @default(cuid())
  userId         String
  moduleId       String
  percentComplete Float   @default(0)
  score          Float?
  timeSpentSecs  Int      @default(0)
  completedAt    DateTime?
  lastAccessedAt DateTime @default(now())
  metadata       Json     @default("{}")

  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  module TrainingModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
  @@map("user_progress")
}

model ActivityAttempt {
  id         String   @id @default(cuid())
  userId     String
  activityId String
  score      Float?
  passed     Boolean  @default(false)
  answers    Json
  timeSecs   Int?
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([activityId])
  @@map("activity_attempts")
}

model LearningEvent {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  eventType      String
  payload        Json
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, eventType])
  @@index([userId, createdAt])
  @@map("learning_events")
}

// ─── IA y conversaciones ─────────────────────────────────────────────────────

model Conversation {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  title          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages     Message[]

  @@index([organizationId, userId])
  @@map("conversations")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  role           String
  content        String   @db.Text
  sources        Json?
  tokensUsed     Int?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("messages")
}

// ─── Reportes y automatización ───────────────────────────────────────────────

model ReportSnapshot {
  id             String   @id @default(cuid())
  organizationId String
  reportType     String
  data           Json
  periodStart    DateTime
  periodEnd      DateTime
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, reportType])
  @@map("report_snapshots")
}

model Automation {
  id             String            @id @default(cuid())
  organizationId String
  name           String
  trigger        AutomationTrigger
  config         Json
  isActive       Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("automations")
}

// ─── ALAE: Accesibilidad e inclusión ─────────────────────────────────────────

model AccessibilityProfile {
  id               String           @id @default(cuid())
  organizationId   String
  userId           String           @unique
  fontScale        Float            @default(1)
  highContrast     Boolean          @default(false)
  darkMode         Boolean          @default(false)
  reduceMotion     Boolean          @default(false)
  preferredModality LearningModality @default(MIXED)
  simplifiedLanguage Boolean          @default(false)
  stepByStepMode   Boolean          @default(false)
  autoReadAloud    Boolean          @default(false)
  captionsEnabled  Boolean          @default(true)
  learningPace     LearningPace     @default(NORMAL)
  wizardCompleted       Boolean          @default(false)
  voiceCommandsEnabled  Boolean          @default(false)
  voiceInputEnabled     Boolean          @default(false)
  assistedReadingMode   Boolean          @default(false)
  declaredNeeds         Json             @default("{}")
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("accessibility_profiles")
}

model LearningProfile {
  id              String        @id @default(cuid())
  organizationId  String
  userId          String        @unique
  modalityScores  Json          @default("{}")
  supportLevel    SupportLevel  @default(STANDARD)
  readingCount    Int           @default(0)
  listeningCount  Int           @default(0)
  visualCount     Int           @default(0)
  practiceCount   Int           @default(0)
  lastAdaptedAt   DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("learning_profiles")
}

model InclusionAudit {
  id              String   @id @default(cuid())
  organizationId  String
  targetType      String
  targetId        String
  overallScore    Float
  dimensions      Json     @default("{}")
  issues          Json     @default("[]")
  recommendations Json     @default("[]")
  aiGenerated     Boolean  @default(true)
  auditedAt       DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, targetType, targetId])
  @@index([organizationId, overallScore])
  @@map("inclusion_audits")
}

model AccessibilityEvent {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  eventType      String
  payload        Json     @default("{}")
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, eventType])
  @@index([userId, createdAt])
  @@map("accessibility_events")
}

model ContentAdaptation {
  id              String   @id @default(cuid())
  organizationId  String
  userId          String?
  sourceType      String
  sourceId        String
  adaptationType  String
  outputContent   Json
  createdAt       DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId, sourceType, sourceId])
  @@index([userId])
  @@map("content_adaptations")
}

model PushSubscription {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  endpoint       String
  p256dh         String
  auth           String
  userAgent      String?
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])
  @@index([organizationId])
  @@map("push_subscriptions")
}
