# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Cappi

# Database — Supabase (Prisma)
# En Supabase: Project Settings → Database → Connection string
# DATABASE_URL = Transaction pooler (puerto 6543) + ?pgbouncer=true
# DIRECT_URL   = Session pooler (puerto 5432) — migraciones y db push
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# Auth
AUTH_SECRET="genera-un-secreto-largo-aleatorio"
AUTH_URL=http://localhost:3000

# Google OAuth
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# IA — proveedor por defecto: gemini | openai | ollama
AI_DEFAULT_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# RAG con documentos (requiere pgvector). Por defecto desactivado = chat directo más estable
RAG_ENABLED=true

# OpenAI (opcional)
OPENAI_API_KEY=

# Ollama local (opcional)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Embeddings (OpenAI legacy; Gemini usa GEMINI_EMBEDDING_MODEL)
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=768

# Vector store: pgvector | pinecone
VECTOR_STORE=pgvector
PINECONE_API_KEY=
PINECONE_INDEX=cappi-embeddings

# Storage: local (desarrollo) | s3 | cloudinary
STORAGE_PROVIDER=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=cappi-documents
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Automatización
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=

# Observabilidad (opcional)
SENTRY_DSN=

# Push notifications (Web Push / PWA)
# Generar: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@tuempresa.com
