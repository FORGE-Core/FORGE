# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=FORGE

# Database — Supabase (Prisma)
# En Supabase: Project Settings → Database → Connection string
# DATABASE_URL = Transaction pooler (puerto 6543) + ?pgbouncer=true
# DIRECT_URL   = Session pooler (puerto 5432) — migraciones y db push
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# Auth
AUTH_SECRET="genera-un-secreto-largo-aleatorio"
AUTH_URL=http://localhost:3000

# Google OAuth
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# IA — proveedor por defecto: gemini | openai | anthropic | ollama
AI_DEFAULT_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Proveedor de embeddings (opcional). Necesario si el chat usa anthropic, ya
# que Claude no genera embeddings: gemini | openai | ollama
EMBEDDING_PROVIDER=

# RAG con documentos (requiere pgvector). Por defecto desactivado = chat directo más estable
RAG_ENABLED=true

# OpenAI (opcional)
OPENAI_API_KEY=

# Anthropic / Claude (opcional). Solo chat — los embeddings usan EMBEDDING_PROVIDER
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Ollama local (opcional)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Embeddings (OpenAI legacy; Gemini usa GEMINI_EMBEDDING_MODEL)
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=768

# Vector store: pgvector | pinecone
VECTOR_STORE=pgvector
PINECONE_API_KEY=
PINECONE_INDEX=forge-embeddings

# Storage: local (desarrollo) | s3 | cloudinary (recomendado en producción)
# Con cloudinary, PDFs/videos/imágenes se sirven desde CDN (menos carga en tu servidor y DB).
STORAGE_PROVIDER=cloudinary
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=forge-documents
# Cloudinary: Dashboard → Programmable Media → API Keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Observabilidad (opcional)
SENTRY_DSN=

# Prisma — activar solo para depurar SQL (muy verboso con Supabase pooler)
# PRISMA_LOG_QUERIES=1

# Push notifications (Web Push / PWA)
# Generar: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@tuempresa.com
